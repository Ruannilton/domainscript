package wallet

import (
	runtime "domainscript/generated/runtime"
)

// Money é um ValueObject composto e imutável (§2.2): sem setters,
// construa sempre via NewMoney para preservar a Regra de Ouro.
type Money struct {
	Amount   runtime.Decimal `json:"amount"`
	Currency string          `json:"currency"`
}

// NewMoney constrói um Money validado.
func NewMoney(amount runtime.Decimal, currency string) (Money, error) {
	if !(amount.Cmp(runtime.NewDecimalFromInt(0)) >= 0) {
		var zero Money
		return zero, runtime.BusinessError{Code: "InvalidMoney", Msg: "Money: valor inválido"}
	}
	return Money{Amount: amount, Currency: currency}, nil
}

// Add é o Operator + de Money (§2.2), gerado a partir do corpo declarado.
func (m Money) Add(other Money) (Money, error) {
	if !(m.Currency == other.Currency) {
		var zero Money
		return zero, ErrCurrencyMismatch
	}
	result, err := NewMoney(m.Amount.Add(other.Amount), m.Currency)
	if err != nil {
		var zero Money
		return zero, err
	}
	return result, nil
}

// Sub é o Operator - de Money (§2.2), gerado a partir do corpo declarado.
func (m Money) Sub(other Money) (Money, error) {
	if !(m.Currency == other.Currency) {
		var zero Money
		return zero, ErrCurrencyMismatch
	}
	if !(m.Amount.Cmp(other.Amount) >= 0) {
		var zero Money
		return zero, ErrNegativeResult
	}
	result, err := NewMoney(m.Amount.Sub(other.Amount), m.Currency)
	if err != nil {
		var zero Money
		return zero, err
	}
	return result, nil
}

// Gte é o Operator >= de Money (§2.2), gerado a partir do corpo declarado.
func (m Money) Gte(other Money) (bool, error) {
	if !(m.Currency == other.Currency) {
		var zero bool
		return zero, ErrCurrencyMismatch
	}
	return m.Amount.Cmp(other.Amount) >= 0, nil
}
