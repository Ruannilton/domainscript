package wallet

import (
	runtime "domainscript/generated/runtime"
)

// WalletCreated é o Event WalletCreated (§4.2): id WalletId, holder HolderName.
type WalletCreated struct {
	runtime.EventMeta
	Id     WalletId   `json:"id"`
	Holder HolderName `json:"holder"`
}

// EventType implementa runtime.Event.
func (*WalletCreated) EventType() string { return "WalletCreated" }

// eventRegistry mapeia o nome estável do evento ao seu construtor Go, para
// (de)serialização quando o tipo concreto não é conhecido estaticamente.
var eventRegistry = map[string]func() runtime.Event{
	"WalletCreated": func() runtime.Event { return &WalletCreated{} },
}

// EventRegistry expõe eventRegistry a quem monta o adapter de persistência
// real (G1, §design 3.11) — cmd/<service>/main.go, pacote diferente deste.
func EventRegistry() map[string]func() runtime.Event {
	return eventRegistry
}
