package ranking

import (
	context "context"
	runtime "domainscript/generated/runtime"
	fmt "fmt"
)

// itemCollection é o runtime.Collection[Item] que "list Item .../count Item ..." (§22.4,
// H4) varrem dentro do execute de uma Policy deste pacote — semeado por um
// "given <binding> [...]" de um Test (gentest.go) nos testes gerados; um
// wiring de produção real (popular a partir de um EventStore/projeção) fica
// para quando um exemplo real precisar dele (mesmo espírito da nota de escopo
// de decl_query.go sobre where/orderBy/skip/take).
var itemCollection = runtime.NewMemoryCollection[Item]()

// policyDispatcher é o runtime.Dispatcher de verdade que Wire (abaixo)
// recebe — o seam que "emit" usa dentro do execute de uma Policy deste
// pacote (H4, §22.4): StmtLowerer.WithEmitDispatch publica DIRETO aqui, já
// que uma Policy não tem "events []runtime.Event" local para acumular
// (assinatura fixa "(ctx, ev) error") — ver a doc do arquivo/lower/stmt.go.
var policyDispatcher runtime.Dispatcher

// FindTopItems é a Policy FindTopItems (§7): reage ao Event RankRequested, entrega BestEffort (in-process, runtime.Dispatcher).
// Assinatura igual a runtime.Dispatcher/Outbox.Subscribe — registrada DIRETO
// como handler pelo wiring do módulo (Wire, abaixo).
func FindTopItems(ctx context.Context, ev runtime.Event) error {
	event, ok := ev.(*RankRequested)
	if !ok {
		return fmt.Errorf("policy FindTopItems: evento inesperado %T (esperava *RankRequested)", ev)
	}
	caller, _ := runtime.CallerFrom(ctx)
	_ = caller
	_ = event
	tmp1, err := itemCollection.Select(ctx, runtime.Query[Item]{Less: func(a, b Item) (bool, error) { return b.Score < a.Score, nil }, OrderField: "score", OrderDesc: true, Skip: 1, Take: 1})
	if err != nil {
		return err
	}
	top := tmp1
	for _, m := range top {
		if err := policyDispatcher.Publish(ctx, &TopItemFound{Id: m.Id}); err != nil {
			return err
		}
	}
	return nil
}

// Wire registra cada Policy deste pacote no runtime.Dispatcher/Outbox (ou,
// para uma Policy cross-service via canal "queue" da topologia, no seu
// próprio runtime.ChannelTransport, var de pacote acima — REQ-26.5) —
// chamada por cmd/<service>/main.go na inicialização (wiring in-memory,
// §design 3.11).
func Wire(d runtime.Dispatcher) {
	policyDispatcher = d
	d.Subscribe("RankRequested", FindTopItems)
}
