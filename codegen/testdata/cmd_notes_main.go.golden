// pingPerTenantLimiter é o limitador perTenant de GET "/ping" -> Ping (spec §16, G4).
var pingPerTenantLimiter runtime.Limiter = runtime.NewLimiter("token_bucket", 2, time.Duration(60000000000), 0)

// pingRateLimitChecks monta as dimensões de rate limit de GET "/ping" -> Ping (spec §16, G4).
func pingRateLimitChecks(ctx context.Context, r *http.Request) []runtime.RateLimitCheck {
	var checks []runtime.RateLimitCheck
	if tenant, ok := runtime.TenantFrom(ctx); ok {
		checks = append(checks, runtime.RateLimitCheck{Limiter: pingPerTenantLimiter, Key: tenant.ID, FailOpen: true})
	}
	return checks
}
