package wallet

import (
	context "context"
	runtime "domainscript/generated/runtime"
	errors "errors"
	reflect "reflect"
	testing "testing"
)

// TestWallet_DepositoNumaCarteiraAtiva prova o cenário "depósito numa carteira ativa" de Test Wallet (§22.1, REQ-31).
func TestWallet_DepositoNumaCarteiraAtiva(t *testing.T) {
	w := &Wallet{}
	w.applyWalletCreated(WalletCreated{Id: "W1", Holder: "Ana"})
	tmp1, err := NewMoney(runtime.NewDecimalFromInt(100), "BRL")
	if err != nil {
		panic(err)
	}
	events, err := w.Deposit(runtime.NewTestCaller(string(w.state.Id)), tmp1, "Salário")
	if err != nil {
		t.Fatalf("esperava sucesso, erro inesperado: %v", err)
	}
	if len(events) != 1 {
		t.Fatalf("esperava 1 evento(s), got %d: %+v", len(events), events)
	}
	tmp2, err := NewMoney(runtime.NewDecimalFromInt(100), "BRL")
	if err != nil {
		panic(err)
	}
	want0 := &DepositPerformed{Id: "W1", Amount: tmp2, Description: "Salário"}
	if !reflect.DeepEqual(events[0], want0) {
		t.Fatalf("evento[%d]: got %+v, want %+v", 0, events[0], want0)
	}
}

// TestWallet_DepositoNumaCarteiraInativaFalha prova o cenário "depósito numa carteira inativa falha" de Test Wallet (§22.1, REQ-31).
func TestWallet_DepositoNumaCarteiraInativaFalha(t *testing.T) {
	w := &Wallet{}
	w.applyWalletCreated(WalletCreated{Id: "W1", Holder: "Ana"})
	w.state.Active = false
	tmp1, err := NewMoney(runtime.NewDecimalFromInt(10), "BRL")
	if err != nil {
		panic(err)
	}
	events, err := w.Deposit(runtime.NewTestCaller(string(w.state.Id)), tmp1, "x")
	if err == nil {
		t.Fatalf("esperava erro InactiveWallet, sucesso com eventos: %+v", events)
	}
	if !errors.Is(err, ErrInactiveWallet) {
		t.Fatalf("esperava errors.Is(err, ErrInactiveWallet), got: %v", err)
	}
}

// TestWallet_SaqueComSaldoSuficiente prova o cenário "saque com saldo suficiente" de Test Wallet (§22.1, REQ-31).
func TestWallet_SaqueComSaldoSuficiente(t *testing.T) {
	w := &Wallet{}
	w.applyWalletCreated(WalletCreated{Id: "W1", Holder: "Ana"})
	tmp1, err := NewMoney(runtime.NewDecimalFromInt(100), "BRL")
	if err != nil {
		panic(err)
	}
	w.applyDepositPerformed(DepositPerformed{Id: "W1", Amount: tmp1, Description: "Salário"})
	tmp2, err := NewMoney(runtime.NewDecimalFromInt(30), "BRL")
	if err != nil {
		panic(err)
	}
	events, err := w.Withdraw(runtime.NewTestCaller(string(w.state.Id)), tmp2, "Mercado")
	if err != nil {
		t.Fatalf("esperava sucesso, erro inesperado: %v", err)
	}
	if len(events) != 1 {
		t.Fatalf("esperava 1 evento(s), got %d: %+v", len(events), events)
	}
	tmp3, err := NewMoney(runtime.NewDecimalFromInt(30), "BRL")
	if err != nil {
		panic(err)
	}
	want0 := &WithdrawalPerformed{Id: "W1", Amount: tmp3, Description: "Mercado"}
	if !reflect.DeepEqual(events[0], want0) {
		t.Fatalf("evento[%d]: got %+v, want %+v", 0, events[0], want0)
	}
}

// TestWallet_SaqueComSaldoInsuficienteFalha prova o cenário "saque com saldo insuficiente falha" de Test Wallet (§22.1, REQ-31).
func TestWallet_SaqueComSaldoInsuficienteFalha(t *testing.T) {
	w := &Wallet{}
	w.applyWalletCreated(WalletCreated{Id: "W1", Holder: "Ana"})
	tmp1, err := NewMoney(runtime.NewDecimalFromInt(20), "BRL")
	if err != nil {
		panic(err)
	}
	w.applyDepositPerformed(DepositPerformed{Id: "W1", Amount: tmp1, Description: "Salário"})
	tmp2, err := NewMoney(runtime.NewDecimalFromInt(50), "BRL")
	if err != nil {
		panic(err)
	}
	events, err := w.Withdraw(runtime.NewTestCaller(string(w.state.Id)), tmp2, "Mercado")
	if err == nil {
		t.Fatalf("esperava erro InsufficientBalance, sucesso com eventos: %+v", events)
	}
	if !errors.Is(err, ErrInsufficientBalance) {
		t.Fatalf("esperava errors.Is(err, ErrInsufficientBalance), got: %v", err)
	}
}

// TestPerformDeposit_DepositoBemSucedidoCommita prova o cenário "depósito bem-sucedido commita" de Test PerformDeposit (§22.2, REQ-31).
func TestPerformDeposit_DepositoBemSucedidoCommita(t *testing.T) {
	store := runtime.NewMemoryEventStore()
	if err := store.Append(context.Background(), "W1", []runtime.Event{&WalletCreated{Id: "W1", Holder: "Ana"}}); err != nil {
		t.Fatalf("given %v: %v", "W1", err)
	}
	uow := runtime.NewUnitOfWork(store)
	Wire(uow)
	ctx := runtime.WithCaller(context.Background(), runtime.NewTestCaller("test-caller"))
	var err error
	tmp1, err := NewMoney(runtime.NewDecimalFromInt(50), "BRL")
	if err != nil {
		panic(err)
	}
	err = PerformDeposit(ctx, Deposit{WalletId: "W1", Amount: tmp1, Description: "Salário"})
	after1, after1Err := store.Load(context.Background(), "W1")
	if after1Err != nil {
		t.Fatalf("Load(\"W1\"): %v", after1Err)
	}
	tmp2, err := NewMoney(runtime.NewDecimalFromInt(50), "BRL")
	if err != nil {
		panic(err)
	}
	after1Want1 := &DepositPerformed{Id: "W1", Amount: tmp2, Description: "Salário"}
	if len(after1) <= 1 {
		t.Fatalf("esperava ao menos 2 evento(s) novo(s) em \"W1\", got %d", len(after1))
	}
	after1[1].SetMeta(runtime.EventMeta{})
	if !reflect.DeepEqual(after1[1], after1Want1) {
		t.Fatalf("\"W1\"[1]: got %+v, want %+v", after1[1], after1Want1)
	}
	if err != nil {
		t.Fatalf("esperava committed (sucesso), erro inesperado: %v", err)
	}
}

// TestPerformDeposit_CarteiraNuncaCriadaFalhaENaoCommita prova o cenário "carteira nunca criada falha e não commita" de Test PerformDeposit (§22.2, REQ-31).
func TestPerformDeposit_CarteiraNuncaCriadaFalhaENaoCommita(t *testing.T) {
	store := runtime.NewMemoryEventStore()
	uow := runtime.NewUnitOfWork(store)
	Wire(uow)
	ctx := runtime.WithCaller(context.Background(), runtime.NewTestCaller("test-caller"))
	var err error
	tmp1, err := NewMoney(runtime.NewDecimalFromInt(50), "BRL")
	if err != nil {
		panic(err)
	}
	err = PerformDeposit(ctx, Deposit{WalletId: "W2", Amount: tmp1, Description: "x"})
	if !errors.Is(err, ErrInactiveWallet) {
		t.Fatalf("esperava errors.Is(err, ErrInactiveWallet), got: %v", err)
	}
	if err == nil {
		t.Fatalf("esperava rolledback (erro), sucesso")
	}
}

// fixtureActiveWallet constrói o Aggregate Wallet semeado pela Fixture activeWallet (§22.6, REQ-31).
func fixtureActiveWallet(t *testing.T) *Wallet {
	t.Helper()
	w := &Wallet{}
	w.applyWalletCreated(WalletCreated{Id: "W1", Holder: "João"})
	tmp1, err := NewMoney(runtime.NewDecimalFromInt(100), "BRL")
	if err != nil {
		panic(err)
	}
	w.applyDepositPerformed(DepositPerformed{Id: "W1", Amount: tmp1, Description: "init"})
	return w
}
