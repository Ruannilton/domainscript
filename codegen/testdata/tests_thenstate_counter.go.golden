package counter

import (
	runtime "domainscript/generated/runtime"
	reflect "reflect"
	testing "testing"
)

// TestCounter_IncrementoLevaOStateAoValorEsperado prova o cenário "incremento leva o state ao valor esperado" de Test Counter (§22.1, REQ-31).
func TestCounter_IncrementoLevaOStateAoValorEsperado(t *testing.T) {
	c := &Counter{}
	c.state.Id = EntityId("C1")
	c.state.Count = Count(1)
	events, err := c.Increment(runtime.NewTestCaller(string(c.state.Id)), Count(5))
	if err != nil {
		t.Fatalf("esperava sucesso, erro inesperado: %v", err)
	}
	for _, ev := range events {
		switch ev := ev.(type) {
		case *CounterIncremented:
			c.applyCounterIncremented(*ev)
		default:
			t.Fatalf("gerador de property (§22.5): evento inesperado retornado por um Handle: %T", ev)
		}
	}
	wantState0 := EntityId("C1")
	if !reflect.DeepEqual(c.state.Id, wantState0) {
		t.Errorf("state.id: got %+v, want %+v", c.state.Id, wantState0)
	}
	wantState1 := Count(5)
	if !reflect.DeepEqual(c.state.Count, wantState1) {
		t.Errorf("state.count: got %+v, want %+v", c.state.Count, wantState1)
	}
}
