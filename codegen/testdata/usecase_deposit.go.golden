package wallet

import (
	context "context"
	runtime "domainscript/generated/runtime"
	time "time"
)

// uow é a unit of work do módulo (§design 3.8), compartilhada por todos os
// UseCases deste pacote — só a declaração de pacote; a instância de verdade
// vem do wiring (E9.1, Wire abaixo).
var uow runtime.UnitOfWork

// Wire injeta a unit of work usada pelos UseCases deste pacote — chamada por
// cmd/<service>/main.go na inicialização (wiring in-memory, §design 3.11).
func Wire(u runtime.UnitOfWork) {
	uow = u
}

// PerformDeposit é o UseCase PerformDeposit (§5.2): abre uma unit of work, executa
// o corpo (load/ensure/dispatch de Handle) e propaga commit/rollback.
func PerformDeposit(ctx context.Context, cmd Deposit) error {
	ctx, cancel := context.WithTimeout(ctx, time.Duration(5000000000))
	defer cancel()
	caller, _ := runtime.CallerFrom(ctx)
	return uow.Run(ctx, func(tx runtime.Tx) error {
		tmp1, err := LoadWallet(tx, cmd.WalletId)
		if err != nil {
			return err
		}
		wallet := tmp1
		events, err := wallet.Deposit(caller, cmd.Amount, cmd.Description)
		if err != nil {
			return err
		}
		if err := tx.Append(string(wallet.id), events); err != nil {
			return err
		}
		return nil
	})
}
