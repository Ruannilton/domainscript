package main

import (
	context "context"
	billing "domainscript/generated/billing"
	catalog "domainscript/generated/catalog"
	runtime "domainscript/generated/runtime"
	search "domainscript/generated/search"
	json "encoding/json"
	errors "errors"
	fmt "fmt"
	log "log"
	net "net"
	http "net/http"
	strconv "strconv"
	strings "strings"
	time "time"
)

// main é o ponto de entrada do service "app" — wiring in-memory a partir de
// mod.ds/topology.ds (§design 3.11). Gerado por dsc gen — sobrescrito a cada
// geração, não editar à mão.
func main() {
	store := runtime.NewMemoryEventStore()
	uow := runtime.NewUnitOfWork(store)
	workerCtx := context.Background()

	billing.Wire(uow)
	go billing.StartIdempotencyCleanup(workerCtx)

	port := "8080"
	server := &http.Server{Addr: fmt.Sprintf(":%s", port), Handler: newMux(store)}
	log.Fatal(server.ListenAndServe())
}

// newMux constrói o *http.ServeMux do service "app", registrando cada rota de
// Interface HTTP (§design 3.12) — função à parte de main() (ver a doc acima)
// para poder ser exercitada por teste via httptest, sem subir um socket real.
func newMux(store runtime.EventStore) *http.ServeMux {
	mux := http.NewServeMux()
	mux.HandleFunc("POST /accounts/{id}/charge", func(w http.ResponseWriter, r *http.Request) {
		caller := devCallerFromRequest(r)
		ctx := runtime.WithCaller(r.Context(), caller)
		ctx = runtime.WithTrace(ctx, runtime.NewTraceID())
		if key := r.Header.Get("Idempotency-Key"); key != "" {
			ctx = runtime.WithIdempotencyKey(ctx, key)
		}
		var cmd billing.ChargeCardCmd
		if r.ContentLength != 0 {
			if err := json.NewDecoder(r.Body).Decode(&cmd); err != nil {
				http.Error(w, fmt.Sprintf("invalid request body: %s", err), http.StatusBadRequest)
				return
			}
		}
		idVal, err := billing.NewAccountId(r.PathValue("id"))
		if err != nil {
			http.Error(w, fmt.Sprintf("invalid path param %q: %s", "id", err), http.StatusBadRequest)
			return
		}
		cmd.AccountId = idVal
		if !billing.ChargeCardIsReplay(ctx, cmd) {
			rlOK, rlResult := runtime.CheckRateLimits(ctx, chargeCardRateLimitChecks(ctx, r))
			if !rlOK {
				writeRateLimitExceeded(w, rlResult)
				return
			}
			writeRateLimitHeaders(w, rlResult)
		}
		ctx, ucSpanEnd := runtime.RecordSpan(ctx, "UseCase.ChargeCard")
		ucErr := billing.ChargeCard(ctx, cmd)
		ucSpanEnd(ucErr)
		if ucErr != nil {
			writeBusinessError(w, ucErr)
			return
		}
		w.WriteHeader(http.StatusNoContent)
	})
	mux.HandleFunc("POST /accounts/{id}/close", func(w http.ResponseWriter, r *http.Request) {
		caller := devCallerFromRequest(r)
		ctx := runtime.WithCaller(r.Context(), caller)
		ctx = runtime.WithTrace(ctx, runtime.NewTraceID())
		if key := r.Header.Get("Idempotency-Key"); key != "" {
			ctx = runtime.WithIdempotencyKey(ctx, key)
		}
		var cmd billing.CloseAccountCmd
		if r.ContentLength != 0 {
			if err := json.NewDecoder(r.Body).Decode(&cmd); err != nil {
				http.Error(w, fmt.Sprintf("invalid request body: %s", err), http.StatusBadRequest)
				return
			}
		}
		idVal, err := billing.NewAccountId(r.PathValue("id"))
		if err != nil {
			http.Error(w, fmt.Sprintf("invalid path param %q: %s", "id", err), http.StatusBadRequest)
			return
		}
		cmd.AccountId = idVal
		if !billing.CloseAccountIsReplay(ctx, cmd) {
			rlOK, rlResult := runtime.CheckRateLimits(ctx, closeAccountRateLimitChecks(ctx, r))
			if !rlOK {
				writeRateLimitExceeded(w, rlResult)
				return
			}
			writeRateLimitHeaders(w, rlResult)
		}
		ctx, ucSpanEnd := runtime.RecordSpan(ctx, "UseCase.CloseAccount")
		ucErr := billing.CloseAccount(ctx, cmd)
		ucSpanEnd(ucErr)
		if ucErr != nil {
			writeBusinessError(w, ucErr)
			return
		}
		w.WriteHeader(http.StatusNoContent)
	})
	mux.HandleFunc("GET /products/{id}", func(w http.ResponseWriter, r *http.Request) {
		caller := devCallerFromRequest(r)
		ctx := runtime.WithCaller(r.Context(), caller)
		ctx = runtime.WithTrace(ctx, runtime.NewTraceID())
		if key := r.Header.Get("Idempotency-Key"); key != "" {
			ctx = runtime.WithIdempotencyKey(ctx, key)
		}
		rlOK, rlResult := runtime.CheckRateLimits(ctx, getProductRateLimitChecks(ctx, r))
		if !rlOK {
			writeRateLimitExceeded(w, rlResult)
			return
		}
		writeRateLimitHeaders(w, rlResult)
		idVal, err := catalog.NewProductId(r.PathValue("id"))
		if err != nil {
			http.Error(w, fmt.Sprintf("invalid path param %q: %s", "id", err), http.StatusBadRequest)
			return
		}
		ctx, qSpanEnd := runtime.RecordSpan(ctx, "Query.GetProduct")
		result, err := catalog.GetProduct(ctx, store, idVal)
		qSpanEnd(err)
		if err != nil {
			writeBusinessError(w, err)
			return
		}
		w.Header().Set("Content-Type", "application/json")
		if err := json.NewEncoder(w).Encode(result); err != nil {
			http.Error(w, fmt.Sprintf("failed to encode response: %s", err), http.StatusInternalServerError)
		}
	})
	mux.HandleFunc("GET /products/{id}/peek", func(w http.ResponseWriter, r *http.Request) {
		caller := devCallerFromRequest(r)
		ctx := runtime.WithCaller(r.Context(), caller)
		ctx = runtime.WithTrace(ctx, runtime.NewTraceID())
		if key := r.Header.Get("Idempotency-Key"); key != "" {
			ctx = runtime.WithIdempotencyKey(ctx, key)
		}
		rlOK, rlResult := runtime.CheckRateLimits(ctx, peekProductRateLimitChecks(ctx, r))
		if !rlOK {
			writeRateLimitExceeded(w, rlResult)
			return
		}
		writeRateLimitHeaders(w, rlResult)
		idVal, err := catalog.NewProductId(r.PathValue("id"))
		if err != nil {
			http.Error(w, fmt.Sprintf("invalid path param %q: %s", "id", err), http.StatusBadRequest)
			return
		}
		ctx, qSpanEnd := runtime.RecordSpan(ctx, "Query.PeekProduct")
		result, err := catalog.PeekProduct(ctx, store, idVal)
		qSpanEnd(err)
		if err != nil {
			writeBusinessError(w, err)
			return
		}
		w.Header().Set("Content-Type", "application/json")
		if err := json.NewEncoder(w).Encode(result); err != nil {
			http.Error(w, fmt.Sprintf("failed to encode response: %s", err), http.StatusInternalServerError)
		}
	})
	mux.HandleFunc("GET /search/{id}", func(w http.ResponseWriter, r *http.Request) {
		caller := devCallerFromRequest(r)
		ctx := runtime.WithCaller(r.Context(), caller)
		ctx = runtime.WithTrace(ctx, runtime.NewTraceID())
		if key := r.Header.Get("Idempotency-Key"); key != "" {
			ctx = runtime.WithIdempotencyKey(ctx, key)
		}
		rlOK, rlResult := runtime.CheckRateLimits(ctx, searchEventsRateLimitChecks(ctx, r))
		if !rlOK {
			writeRateLimitExceeded(w, rlResult)
			return
		}
		writeRateLimitHeaders(w, rlResult)
		idVal, err := search.NewQueryTermId(r.PathValue("id"))
		if err != nil {
			http.Error(w, fmt.Sprintf("invalid path param %q: %s", "id", err), http.StatusBadRequest)
			return
		}
		ctx, qSpanEnd := runtime.RecordSpan(ctx, "Query.SearchEvents")
		result, err := search.SearchEvents(ctx, store, idVal)
		qSpanEnd(err)
		if err != nil {
			writeBusinessError(w, err)
			return
		}
		w.Header().Set("Content-Type", "application/json")
		if err := json.NewEncoder(w).Encode(result); err != nil {
			http.Error(w, fmt.Sprintf("failed to encode response: %s", err), http.StatusInternalServerError)
		}
	})
	return mux
}

// devCallerFromRequest constrói um runtime.Caller de DESENVOLVIMENTO a partir
// do header "X-Caller-Id" (§design 3.12): presente e não-vazio ->
// Authenticated()==true, ID()==valor do header; ausente -> Authenticated()==
// false, ID()=="". Placeholder até a borda de auth real chegar; HasRole
// sempre devolve false.
func devCallerFromRequest(r *http.Request) runtime.Caller {
	id := r.Header.Get("X-Caller-Id")
	return devCaller{authenticated: id != "", id: id}
}

// devCaller implementa runtime.Caller para o caller de dev acima.
type devCaller struct {
	authenticated bool
	id            string
}

func (c devCaller) Authenticated() bool {
	return c.authenticated
}

func (c devCaller) ID() string {
	return c.id
}

func (c devCaller) HasRole(role string) bool {
	return false
}

// writeBusinessError mapeia err a um status HTTP (§design 3.12, REQ-28.2):
// distingue por errors.As(&runtime.BusinessError) — negócio -> 422, exceto
// runtime.ErrForbidden (403), runtime.ErrNotFound (404) e
// runtime.ErrIdempotencyInFlight (409, G2, spec §14 — corrida da mesma
// Idempotency-Key sob "concurrentRetry: reject"); qualquer outro error
// (infra) -> 503. runtime.ErrIdempotencyKeyConflict/ErrIdempotencyKeyRequired
// (G2) caem no default (422) DE PROPÓSITO — REQ-20.4 pede 422 para o
// conflito, que já é o que o default produz; não precisam de um case à
// parte, ao contrário de Forbidden/NotFound/InFlight, que DEVIAM do default.
// runtime.ErrNotFound (404) também é o que um Load/Query devolve para um
// aggregate de OUTRO tenant (G5, spec §13.2, row_level) — o mesmo caminho de
// "não encontrado", de propósito: cross-tenant nunca deve vazar um 403 (evita
// enumeração). Rate-limit (429, G4) e tenant ausente (400 fail-closed, G5) são
// resolvidos À PARTE, ANTES desta função sequer ser chamada (writeRateLimitExceeded/
// requireTenant, ver as rotas acima) — nenhum dos dois chega a err aqui. Sunset
// (410) continua marco posterior (G6) — deliberadamente não tratado aqui, para
// não travar a extensão futura com suposições erradas.
func writeBusinessError(w http.ResponseWriter, err error) {
	var be runtime.BusinessError
	if errors.As(err, &be) {
		switch {
		case errors.Is(err, runtime.ErrForbidden):
			http.Error(w, be.Msg, http.StatusForbidden)
		case errors.Is(err, runtime.ErrNotFound):
			http.Error(w, be.Msg, http.StatusNotFound)
		case errors.Is(err, runtime.ErrIdempotencyInFlight):
			http.Error(w, be.Msg, http.StatusConflict)
		default:
			http.Error(w, be.Msg, http.StatusUnprocessableEntity)
		}
		return
	}
	http.Error(w, "internal error", http.StatusServiceUnavailable)
}

// rateLimitClientIP extrai o identificador de rede do chamador para a
// dimensão perIp (spec §16): prioriza "X-Forwarded-For" (1º endereço da
// lista — convenção padrão de proxy reverso) e cai para r.RemoteAddr (só o
// host, sem a porta) na ausência do header. Nenhum dos dois é validado
// contra spoofing — confiar (ou não) num proxy é decisão de deploy, fora do
// escopo deste gerador.
func rateLimitClientIP(r *http.Request) string {
	if fwd := r.Header.Get("X-Forwarded-For"); fwd != "" {
		if i := strings.IndexByte(fwd, ','); i >= 0 {
			fwd = fwd[:i]
		}
		return strings.TrimSpace(fwd)
	}
	if host, _, err := net.SplitHostPort(r.RemoteAddr); err == nil {
		return host
	}
	return r.RemoteAddr
}

// rateLimitAPIKey extrai a chave de API para a dimensão perApiKey (spec
// §16) do header "X-Api-Key" — placeholder documentado até o projeto ter
// um sistema de autenticação por API key de verdade (nenhum existe ainda;
// mesmo espírito do X-Caller-Id de dev, devCallerFromRequest acima).
func rateLimitAPIKey(r *http.Request) string {
	return r.Header.Get("X-Api-Key")
}

// writeRateLimitHeaders escreve os headers "X-RateLimit-*" (spec §16) a
// partir do resultado MAIS RESTRITIVO entre as dimensões checadas
// (runtime.CheckRateLimits já resolve qual) — emitido tanto no caminho de
// sucesso quanto no 429, para o chamador sempre poder ver sua cota.
func writeRateLimitHeaders(w http.ResponseWriter, res runtime.RateLimitResult) {
	w.Header().Set("X-RateLimit-Limit", strconv.Itoa(res.Limit))
	w.Header().Set("X-RateLimit-Remaining", strconv.Itoa(res.Remaining))
	w.Header().Set("X-RateLimit-Reset", strconv.FormatInt(res.ResetAt.Unix(), 10))
}

// writeRateLimitExceeded escreve a resposta automática do spec §16: os
// mesmos headers X-RateLimit-* de sempre, mais "Retry-After" (segundos,
// arredondado para cima) e 429.
func writeRateLimitExceeded(w http.ResponseWriter, res runtime.RateLimitResult) {
	writeRateLimitHeaders(w, res)
	retryAfterSeconds := int64(res.RetryAfter / time.Second)
	if res.RetryAfter%time.Second != 0 {
		retryAfterSeconds++
	}
	if retryAfterSeconds < 0 {
		retryAfterSeconds = 0
	}
	w.Header().Set("Retry-After", strconv.FormatInt(retryAfterSeconds, 10))
	http.Error(w, "rate limit exceeded", http.StatusTooManyRequests)
}

// chargeCardPerIpLimiter é o limitador perIp de POST "/accounts/{id}/charge" -> ChargeCard (spec §16, G4).
var chargeCardPerIpLimiter runtime.Limiter = runtime.NewLimiter("token_bucket", 5, time.Duration(60000000000), 2)

// chargeCardGlobalLimiter é o limitador global de POST "/accounts/{id}/charge" -> ChargeCard (spec §16, G4).
var chargeCardGlobalLimiter runtime.Limiter = runtime.NewLimiter("token_bucket", 1000, time.Duration(60000000000), 2)

// chargeCardRateLimitChecks monta as dimensões de rate limit de POST "/accounts/{id}/charge" -> ChargeCard (spec §16, G4).
func chargeCardRateLimitChecks(ctx context.Context, r *http.Request) []runtime.RateLimitCheck {
	var checks []runtime.RateLimitCheck
	checks = append(checks, runtime.RateLimitCheck{Limiter: chargeCardPerIpLimiter, Key: rateLimitClientIP(r), FailOpen: true})
	checks = append(checks, runtime.RateLimitCheck{Limiter: chargeCardGlobalLimiter, Key: "", FailOpen: true})
	return checks
}

// closeAccountPerIpLimiter é o limitador perIp de POST "/accounts/{id}/close" -> CloseAccount (spec §16, G4).
var closeAccountPerIpLimiter runtime.Limiter = runtime.NewLimiter("token_bucket", 1, time.Duration(60000000000), 0)

// closeAccountRateLimitChecks monta as dimensões de rate limit de POST "/accounts/{id}/close" -> CloseAccount (spec §16, G4).
func closeAccountRateLimitChecks(ctx context.Context, r *http.Request) []runtime.RateLimitCheck {
	var checks []runtime.RateLimitCheck
	checks = append(checks, runtime.RateLimitCheck{Limiter: closeAccountPerIpLimiter, Key: rateLimitClientIP(r), FailOpen: true})
	return checks
}

// getProductPerUserLimiter é o limitador perUser de GET "/products/{id}" -> GetProduct (spec §16, G4).
var getProductPerUserLimiter runtime.Limiter = runtime.NewLimiter("sliding_window", 10, time.Duration(60000000000), 0)

// getProductRateLimitChecks monta as dimensões de rate limit de GET "/products/{id}" -> GetProduct (spec §16, G4).
func getProductRateLimitChecks(ctx context.Context, r *http.Request) []runtime.RateLimitCheck {
	var checks []runtime.RateLimitCheck
	if caller, ok := runtime.CallerFrom(ctx); ok && caller.Authenticated() {
		checks = append(checks, runtime.RateLimitCheck{Limiter: getProductPerUserLimiter, Key: caller.ID(), FailOpen: true})
	}
	return checks
}

// peekProductPerUserLimiter é o limitador perUser de GET "/products/{id}/peek" -> PeekProduct (spec §16, G4).
var peekProductPerUserLimiter runtime.Limiter = runtime.NewLimiter("sliding_window", 10, time.Duration(60000000000), 0)

// peekProductRateLimitChecks monta as dimensões de rate limit de GET "/products/{id}/peek" -> PeekProduct (spec §16, G4).
func peekProductRateLimitChecks(ctx context.Context, r *http.Request) []runtime.RateLimitCheck {
	var checks []runtime.RateLimitCheck
	if caller, ok := runtime.CallerFrom(ctx); ok && caller.Authenticated() {
		checks = append(checks, runtime.RateLimitCheck{Limiter: peekProductPerUserLimiter, Key: caller.ID(), FailOpen: false})
	}
	return checks
}

// searchEventsFreePerUserLimiter é o limitador perUser de GET "/search/{id}" -> SearchEvents (tier Free) (spec §16, G4).
var searchEventsFreePerUserLimiter runtime.Limiter = runtime.NewLimiter("fixed_window", 100, time.Duration(60000000000), 0)

// searchEventsFreePerTenantLimiter é o limitador perTenant de GET "/search/{id}" -> SearchEvents (tier Free) (spec §16, G4).
var searchEventsFreePerTenantLimiter runtime.Limiter = runtime.NewLimiter("fixed_window", 1000, time.Duration(60000000000), 0)

// searchEventsProPerUserLimiter é o limitador perUser de GET "/search/{id}" -> SearchEvents (tier Pro) (spec §16, G4).
var searchEventsProPerUserLimiter runtime.Limiter = runtime.NewLimiter("fixed_window", 1000, time.Duration(60000000000), 0)

// searchEventsProPerTenantLimiter é o limitador perTenant de GET "/search/{id}" -> SearchEvents (tier Pro) (spec §16, G4).
var searchEventsProPerTenantLimiter runtime.Limiter = runtime.NewLimiter("fixed_window", 20000, time.Duration(60000000000), 0)

// searchEventsRateLimitChecks resolve o RateLimitTier de tenant.Tier (spec §16: "byTier") e monta
// as dimensões QUE ESSE TIER declara — sem tenant/tier resolvido, ou com um
// nome de tier desconhecido, devolve nil: nenhuma dimensão de tier se
// aplica a esta requisição (mesmo princípio de "rotas sem tenant só perIp"
// generalizado, ver a doc do arquivo) em vez de um erro.
func searchEventsRateLimitChecks(ctx context.Context, r *http.Request) []runtime.RateLimitCheck {
	tenant, ok := runtime.TenantFrom(ctx)
	if !ok || tenant.Tier == "" {
		return nil
	}
	switch tenant.Tier {
	case "Free":
		var checks []runtime.RateLimitCheck
		if caller, ok := runtime.CallerFrom(ctx); ok && caller.Authenticated() {
			checks = append(checks, runtime.RateLimitCheck{Limiter: searchEventsFreePerUserLimiter, Key: caller.ID(), FailOpen: true})
		}
		if tenant, ok := runtime.TenantFrom(ctx); ok {
			checks = append(checks, runtime.RateLimitCheck{Limiter: searchEventsFreePerTenantLimiter, Key: tenant.ID, FailOpen: true})
		}
		return checks
	case "Pro":
		var checks []runtime.RateLimitCheck
		if caller, ok := runtime.CallerFrom(ctx); ok && caller.Authenticated() {
			checks = append(checks, runtime.RateLimitCheck{Limiter: searchEventsProPerUserLimiter, Key: caller.ID(), FailOpen: true})
		}
		if tenant, ok := runtime.TenantFrom(ctx); ok {
			checks = append(checks, runtime.RateLimitCheck{Limiter: searchEventsProPerTenantLimiter, Key: tenant.ID, FailOpen: true})
		}
		return checks
	default:
		return nil
	}
}
