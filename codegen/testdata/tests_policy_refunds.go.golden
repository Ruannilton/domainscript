package refunds

import (
	context "context"
	runtime "domainscript/generated/runtime"
	reflect "reflect"
	testing "testing"
)

// TestRefundAllOnEventCancelled_ReembolsoDeTodosOsPedidos prova o cenário "reembolso de todos os pedidos" de Test RefundAllOnEventCancelled (§22.4, REQ-31).
func TestRefundAllOnEventCancelled_ReembolsoDeTodosOsPedidos(t *testing.T) {
	ctx := context.Background()
	ticketCollection = runtime.NewMemoryCollection[Ticket]()
	item1 := Ticket{}
	item1.EventId = EventId("E1")
	item1.Status = TicketStatusSold
	item1.OrderId = OrderId("O1")
	if err := ticketCollection.Add(ctx, item1); err != nil {
		t.Fatalf("given Ticket: %v", err)
	}
	item2 := Ticket{}
	item2.EventId = EventId("E1")
	item2.Status = TicketStatusSold
	item2.OrderId = OrderId("O1")
	if err := ticketCollection.Add(ctx, item2); err != nil {
		t.Fatalf("given Ticket: %v", err)
	}
	item3 := Ticket{}
	item3.EventId = EventId("E1")
	item3.Status = TicketStatusSold
	item3.OrderId = OrderId("O2")
	if err := ticketCollection.Add(ctx, item3); err != nil {
		t.Fatalf("given Ticket: %v", err)
	}
	var published []runtime.Event
	policyDispatcher = runtime.NewDispatcher()
	collect := func(ctx context.Context, ev runtime.Event) error {
		published = append(published, ev)
		return nil
	}
	policyDispatcher.Subscribe("RefundRequested", collect)
	ev := EventCancelled{Id: EventId("E1"), Reason: CancellationReason("Chuva")}
	err := RefundAllOnEventCancelled(ctx, &ev)
	if err != nil {
		t.Fatalf("esperava sucesso ao invocar RefundAllOnEventCancelled, erro inesperado: %v", err)
	}
	want1 := &RefundRequested{OrderId: OrderId("O1"), Reason: RefundReason("Evento cancelado")}
	found1 := false
	for _, got := range published {
		if reflect.DeepEqual(got, want1) {
			found1 = true
		}
	}
	if !found1 {
		t.Fatalf("esperava emitted %+v entre os eventos publicados, got %+v", want1, published)
	}
	want2 := &RefundRequested{OrderId: OrderId("O2"), Reason: RefundReason("Evento cancelado")}
	found2 := false
	for _, got := range published {
		if reflect.DeepEqual(got, want2) {
			found2 = true
		}
	}
	if !found2 {
		t.Fatalf("esperava emitted %+v entre os eventos publicados, got %+v", want2, published)
	}
	wantCount3 := 2
	if len(published) != wantCount3 {
		t.Fatalf("esperava %d evento(s) publicado(s), got %d: %+v", wantCount3, len(published), published)
	}
}

// TestRefundAllOnEventCancelled_NenhumTicketDoEventoCanceladoGeraZeroReembolsos prova o cenário "nenhum ticket do evento cancelado gera zero reembolsos" de Test RefundAllOnEventCancelled (§22.4, REQ-31).
func TestRefundAllOnEventCancelled_NenhumTicketDoEventoCanceladoGeraZeroReembolsos(t *testing.T) {
	ctx := context.Background()
	ticketCollection = runtime.NewMemoryCollection[Ticket]()
	item1 := Ticket{}
	item1.EventId = EventId("E9")
	item1.Status = TicketStatusSold
	item1.OrderId = OrderId("O9")
	if err := ticketCollection.Add(ctx, item1); err != nil {
		t.Fatalf("given Ticket: %v", err)
	}
	var published []runtime.Event
	policyDispatcher = runtime.NewDispatcher()
	collect := func(ctx context.Context, ev runtime.Event) error {
		published = append(published, ev)
		return nil
	}
	policyDispatcher.Subscribe("RefundRequested", collect)
	ev := EventCancelled{Id: EventId("E1"), Reason: CancellationReason("Chuva")}
	err := RefundAllOnEventCancelled(ctx, &ev)
	if err != nil {
		t.Fatalf("esperava sucesso ao invocar RefundAllOnEventCancelled, erro inesperado: %v", err)
	}
	wantCount1 := 0
	if len(published) != wantCount1 {
		t.Fatalf("esperava %d evento(s) publicado(s), got %d: %+v", wantCount1, len(published), published)
	}
}
