// wallet.test.ds — testes nativos do Aggregate Wallet (§22).
// Cada cenário descreve `given` (eventos passados) → `when` (um Handle) → `then`
// (eventos emitidos, ou um erro de negócio). Cobrir o caminho de erro de cada
// Handle silencia o aviso de cobertura (REQ-5.22).
Test Wallet {
    scenario "depósito numa carteira ativa" {
        given [
            WalletCreated(id: "W1", holder: "Ana")
        ]
        when Deposit(amount: Money(100, "BRL"), description: "Salário")
        then [ DepositPerformed(id: "W1", amount: Money(100, "BRL"), description: "Salário") ]
    }

    scenario "depósito numa carteira inativa falha" {
        given [
            WalletCreated(id: "W1", holder: "Ana")
        ]
        // Apply WalletCreated semeia active=true (ver domain.ds) — este
        // segundo given sobrescreve state.active para exercitar o caminho de
        // erro do Handle.
        given state { active: false }
        when Deposit(amount: Money(10, "BRL"), description: "x")
        then error InactiveWallet
    }

    scenario "saque com saldo suficiente" {
        given [
            WalletCreated(id: "W1", holder: "Ana"),
            DepositPerformed(id: "W1", amount: Money(100, "BRL"), description: "Salário")
        ]
        when Withdraw(amount: Money(30, "BRL"), description: "Mercado")
        then [ WithdrawalPerformed(id: "W1", amount: Money(30, "BRL"), description: "Mercado") ]
    }

    scenario "saque com saldo insuficiente falha" {
        given [
            WalletCreated(id: "W1", holder: "Ana"),
            DepositPerformed(id: "W1", amount: Money(20, "BRL"), description: "Salário")
        ]
        when Withdraw(amount: Money(50, "BRL"), description: "Mercado")
        then error InsufficientBalance
    }
}

// Test PerformDeposit — asserção transacional sobre o UseCase PerformDeposit
// (§22.2, H4): "given Subject from [...]" semeia o EventStore de verdade que
// PerformDeposit's "load Wallet(cmd.walletId)" lê; "then { Subject emitted
// ..., committed }" verifica o evento persistido no stream do Subject.
Test PerformDeposit {
    scenario "depósito bem-sucedido commita" {
        given Wallet("W1") from [ WalletCreated(id: "W1", holder: "Ana") ]
        when Deposit(walletId: "W1", amount: Money(50, "BRL"), description: "Salário")
        then {
            Wallet("W1") emitted DepositPerformed(id: "W1", amount: Money(50, "BRL"), description: "Salário")
            committed
        }
    }

    scenario "carteira nunca criada falha e não commita" {
        when Deposit(walletId: "W2", amount: Money(50, "BRL"), description: "x")
        then { error InactiveWallet, rolledback }
    }
}

// Fixture activeWallet — pré-condição reutilizável (§22.6, H4): descreve uma
// carteira ativa com saldo, sem when/then. Gera "func fixtureActiveWallet(t
// *testing.T) *Wallet", que constrói o Aggregate direto e o semeia com os
// eventos abaixo (Apply real: WalletCreated seta active/balance zerado,
// DepositPerformed acumula o saldo — mesma máquina de given de §22.1). O helper
// não tem chamador no projeto gerado (a gramática não liga Fixture a Test) — é
// exercitado por um teste comportamental escrito à mão (gentest_test.go).
Fixture activeWallet {
    Wallet("W1") from [
        WalletCreated(id: "W1", holder: "João"),
        DepositPerformed(id: "W1", amount: Money(100, "BRL"), description: "init")
    ]
}
